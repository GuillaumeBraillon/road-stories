#!/bin/bash

# Hook post-commit : Crée automatiquement un tag Git basé sur la version du CHANGELOG
# Ce hook s'exécute APRÈS chaque commit et tag la version si nécessaire

# Extraire la dernière version du CHANGELOG (format: ## [X.Y.Z])
CHANGELOG_VERSION=$(grep -m 1 "^## \[" CHANGELOG.md | sed -E 's/^## \[([0-9]+\.[0-9]+\.[0-9]+)\].*/\1/')

if [ -z "$CHANGELOG_VERSION" ]; then
  # Pas de version trouvée dans le CHANGELOG, on laisse passer
  exit 0
fi

TAG_NAME="v$CHANGELOG_VERSION"

# Vérifier si le tag existe déjà
if git rev-parse "$TAG_NAME" >/dev/null 2>&1; then
  echo "ℹ️  Tag $TAG_NAME existe déjà"
  exit 0
fi

# Extraire la description courte du CHANGELOG (première ligne après la version)
DESCRIPTION=$(grep -A 5 "^## \[$CHANGELOG_VERSION\]" CHANGELOG.md | grep -m 1 "^### " | sed 's/^### //')

if [ -z "$DESCRIPTION" ]; then
  # Si pas de section trouvée, utiliser une description générique
  DESCRIPTION="Release $CHANGELOG_VERSION"
fi

# Créer le tag annoté
echo "🏷️  Création du tag $TAG_NAME"
git tag -a "$TAG_NAME" -m "Version $CHANGELOG_VERSION - $DESCRIPTION"

echo "✅ Tag $TAG_NAME créé avec succès !"
echo ""
echo "📤 Pour pousser vers GitHub :"
echo "   git push origin main --tags"
echo "   ou : git push origin $TAG_NAME"

exit 0
